# ─── Telegram MTProto (user account, for reading) ───────────────────
# Create an application at https://my.telegram.org/apps to get these.
# If that page errors out, the publicly known Telegram Desktop creds
# work too (open-source Telegram clients ship with them):
#   TG_API_ID=2040
#   TG_API_HASH=b18441a1ff607e10a989891a5462e627
TG_API_ID=
TG_API_HASH=

# Only needed for the one-time bootstrap_login.py.
TG_PHONE=+15551234567

# ─── Bot (for posting) ──────────────────────────────────────────────
# Talk to @BotFather, create a new bot, copy its token here. Then add
# the bot to the chat where you want digests posted.
TELEGRAM_BOT_TOKEN=

# Destination chat. Supergroup IDs start with -100.
OUTPUT_CHAT_ID=-100123456789
# Forum topic id, or leave empty for a plain group chat.
OUTPUT_THREAD_ID=

# ─── LLM (any OpenAI-compatible endpoint) ───────────────────────────
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
